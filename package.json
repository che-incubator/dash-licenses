{
  "name": "license-tool",
  "version": "2.0.0",
  "description": "Node.js library for dependency license analysis using ClearlyDefined API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "license-tool": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/che-incubator/dash-licenses.git"
  },
  "author": "Red Hat, Inc.",
  "license": "EPL-2.0",
  "keywords": [
    "license",
    "dependencies",
    "eclipse",
    "dash",
    "clearlydefined",
    "node"
  ],
  "bugs": {
    "url": "https://github.com/che-incubator/dash-licenses/issues"
  },
  "homepage": "https://github.com/che-incubator/dash-licenses#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist/ *.tsbuildinfo",
    "prebuild": "npm run clean",
    "build": "webpack --mode production",
    "postbuild": "chmod +x dist/cli.js",
    "build:dev": "webpack --mode development",
    "build:watch": "webpack --mode development --watch",
    "build:clean": "npm run clean && npm run build",
    "dev": "ts-node src/document/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" --fix",
    "header:check": "node header-check.js",
    "header:fix": "node header-check.js --fix",
    "header:verbose": "node header-check.js --verbose",
    "type-check": "tsc --noEmit",
    "prepack": "webpack --mode production && chmod +x dist/cli.js"
  },
  "dependencies": {
    "@eslint/eslintrc": "3.3.4",
    "@yarnpkg/parsers": "^3.0.3",
    "axios": "^1.13.5",
    "chalk": "^4.1.2",
    "loglevel": "^1.9.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.3",
    "eslint-plugin-notice": "^1.0.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "minimatch@9": "9.0.9",
    "terser-webpack-plugin": "5.4.0",
    "qs": "6.14.2",
    "lodash": "4.17.23"
  }
}
